# 复制此文件为 .env，然后填入你的 API Key

# ── 主模型（DeepSeek，用于文本生成）────
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型选择: deepseek-chat / deepseek-reasoner
MODEL_NAME=deepseek-chat

# ── 视觉模型（可选，用于产品图片分析）──
# DeepSeek 不支持图片识别。如需图片分析，填一个支持多模态的模型。
# 推荐：gpt-4o / gpt-4o-mini / glm-4v / qwen-vl-plus
# 不填则跳过图片分析，由 Research Agent 根据文本信息推断产品属性。
VISION_MODEL_NAME=
VISION_API_KEY=
VISION_BASE_URL=
