# 复制此文件为 .env，然后填入你的 API Key
# DeepSeek API Key（在 platform.deepseek.com 申请，充值 10 元够用很久）
DEEPSEEK_API_KEY=sk-f7743fd63f194b8cbe728f6022e53a9f
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型选择（可改）
# 选项: deepseek-chat / deepseek-reasoner
MODEL_NAME=deepseek-v4-pro

# ── 视觉模型（可选，用于产品图片分析）──
# DeepSeek 不支持图片识别。如需图片分析，填一个支持多模态的模型。
# 推荐：gpt-4o / gpt-4o-mini / glm-4v / qwen-vl-plus
VISION_MODEL_NAME=qwen3-VL
VISION_API_KEY=sk-f72c4983334c4ace891f26228aec6ce4
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
